---
import '../styles/global.css';

interface Props {
	title: string;
	currentPath?: string;
}

const { title, currentPath = '/' } = Astro.props;

const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/products', label: '产品中心' },
	{ href: '/news', label: '资讯动态' },
	{ href: '/about', label: '关于我们' },
	{ href: '/contact', label: '联系我们' },
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="立刷POS官网 - 您的全能支付助手" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/images/logo.webp" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-50 text-gray-900 font-sans">
		<header class="bg-white shadow-sm sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between h-16 items-center">
					<div class="flex items-center">
						<a href="/" class="flex-shrink-0 flex items-center gap-2">
							<img class="h-8 w-auto rounded-sm" src="/images/logo.webp" alt="立刷 Logo" />
							<span class="font-bold text-xl text-blue-600">立刷</span>
						</a>
					</div>
					
					<nav class="hidden md:flex space-x-8 items-center">
					{navItems.map((item) => (
						item.href === '/news' ? (
							<div class="relative group">
								<a href={item.href} class:list={[
									'px-3 py-2 rounded-md text-sm font-medium transition-colors inline-flex items-center gap-1',
									currentPath === item.href ? 'text-gray-900' : 'text-gray-500 hover:text-blue-600',
								]}>
									{item.label}
									<svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
								</a>
								<div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
									<div class="bg-white rounded-xl shadow-lg border border-gray-100 py-2 min-w-[220px]">
									<a href="/news/pos-guide-2026" class="block px-4 py-2.5 text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-colors">2026立刷POS办理使用指南</a>
									<a href="/news" class="block px-4 py-2.5 text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-colors border-t border-gray-50">资讯指南</a>
								</div>
								</div>
							</div>
						) : (
							<a href={item.href} class:list={[
								'px-3 py-2 rounded-md text-sm font-medium transition-colors',
								currentPath === item.href ? 'text-gray-900' : 'text-gray-500 hover:text-blue-600',
							]}>
								{item.label}
							</a>
						)
					))}
				</nav>

					<div class="flex items-center md:hidden">
						<button type="button" id="mobile-menu-button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-blue-500" aria-expanded="false">
							<span class="sr-only">打开主菜单</span>
							<svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
							</svg>
						</button>
					</div>
				</div>
			</div>

			<div class="md:hidden hidden" id="mobile-menu">
				<div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 bg-white border-t border-gray-100 shadow-lg">
					{navItems.map((item) => (
						item.href === '/news' ? (
							<div>
								<a href={item.href} class:list={[
									'block px-3 py-2 rounded-md text-base font-medium hover:text-blue-600 hover:bg-gray-50',
									currentPath === item.href ? 'text-gray-900' : 'text-gray-500',
								]}>
									{item.label}
								</a>
								<div class="pl-4 space-y-1">
									<a href="/news/pos-guide-2026" class="block px-3 py-1.5 rounded-md text-sm text-gray-500 hover:text-blue-600 hover:bg-gray-50">2026立刷POS办理使用指南</a>
									<a href="/news" class="block px-3 py-1.5 rounded-md text-sm text-gray-500 hover:text-blue-600 hover:bg-gray-50">资讯指南</a>
								</div>
							</div>
						) : (
							<a href={item.href} class:list={[
								'block px-3 py-2 rounded-md text-base font-medium hover:text-blue-600 hover:bg-gray-50',
								currentPath === item.href ? 'text-gray-900' : 'text-gray-500',
							]}>
								{item.label}
							</a>
						)
					))}
				</div>
			</div>
		</header>

		<main class="min-h-screen">
			<slot />
		</main>

		<footer class="bg-gray-900 text-white mt-12 pt-16 pb-10">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 mb-12">
					<div>
						<div class="flex items-center gap-2 mb-5">
							<img class="h-9 w-auto rounded-sm" src="/images/logo.webp" alt="立刷 Logo" />
							<span class="font-bold text-xl tracking-wider">立刷POS</span>
						</div>
						<p class="text-gray-400 text-sm leading-relaxed mb-6">
							立刷致力于为小微商户提供安全、便捷、高效的支付解决方案，助力千万商家数字化经营。
						</p>
					</div>
					<div>
						<h3 class="text-sm font-semibold uppercase tracking-wider mb-5 text-gray-300">产品服务</h3>
						<ul class="space-y-3">
							<li><a href="/products" class="text-gray-400 hover:text-white transition-colors text-sm">立刷骐骥版</a></li>
							<li><a href="/products" class="text-gray-400 hover:text-white transition-colors text-sm">立刷畅想版</a></li>
							<li><a href="/contact" class="text-gray-400 hover:text-white transition-colors text-sm">免费申请</a></li>
							<li><a href="/contact" class="text-gray-400 hover:text-white transition-colors text-sm">售后服务</a></li>
						</ul>
					</div>
					<div>
						<h3 class="text-sm font-semibold uppercase tracking-wider mb-5 text-gray-300">快速链接</h3>
						<ul class="space-y-3">
							<li><a href="/" class="text-gray-400 hover:text-white transition-colors text-sm">首页</a></li>
							<li><a href="/products" class="text-gray-400 hover:text-white transition-colors text-sm">产品中心</a></li>
							<li><a href="/news" class="text-gray-400 hover:text-white transition-colors text-sm">资讯动态</a></li>
							<li><a href="/about" class="text-gray-400 hover:text-white transition-colors text-sm">关于我们</a></li>
							<li><a href="/contact" class="text-gray-400 hover:text-white transition-colors text-sm">联系我们</a></li>
						</ul>
					</div>
					<div>
						<h3 class="text-sm font-semibold uppercase tracking-wider mb-5 text-gray-300">联系我们</h3>
						<ul class="space-y-3 text-sm text-gray-400">
							<li class="flex items-center gap-2">
								<svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
								<a href="tel:400-926-6655" class="hover:text-white transition-colors">400-926-6655</a>
							</li>
							<li class="flex items-start gap-2">
								<svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
								深圳市南山区嘉联支付大厦
							</li>
							<li class="flex items-center gap-2">
								<svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
								7x24小时全天候服务
							</li>
						</ul>
					</div>
					<div class="flex flex-col items-center">
						<h3 class="text-sm font-semibold uppercase tracking-wider mb-5 text-gray-300 self-center">微信客服</h3>
						<img src="/images/微信客服.jpg" alt="微信客服二维码" class="w-28 h-28 rounded-xl object-cover border-2 border-gray-700" />
						<p class="text-gray-500 text-xs mt-3">扫码添加客服</p>
					</div>
				</div>
				<div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-gray-500 text-sm">&copy; {new Date().getFullYear()} 立刷POS. All rights reserved.</p>
					<div class="text-gray-600 text-xs">
						<a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer" class="hover:text-gray-400 transition-colors">蜀ICP备17001485号-1</a>
					</div>
				</div>
			</div>
		</footer>

		<!-- 侧边悬浮客服抽屉 -->
		<div id="contact-drawer" class="fixed right-0 top-1/2 -translate-y-1/2 z-50 transition-transform duration-300 translate-x-full md:hover:translate-x-0 group flex shadow-2xl rounded-l-lg">
			<!-- 左侧突出 Tab -->
			<div id="contact-drawer-tab" class="absolute -left-10 top-0 w-10 bg-blue-600 text-white rounded-l-lg flex flex-col items-center py-4 cursor-pointer shadow-[-4px_0_10px_rgba(0,0,0,0.1)]">
				<svg class="w-6 h-6 mb-2" fill="currentColor" viewBox="0 0 24 24">
					<path d="M12 1a9 9 0 0 0-9 9v7c0 1.66 1.34 3 3 3h3v-8H5v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h-4v8h3c1.66 0 3-1.34 3-3v-7a9 9 0 0 0-9-9z"/>
				</svg>
				<div class="text-[14px] font-bold my-1 flex flex-col gap-0.5 items-center">
					<span>联</span>
					<span>系</span>
					<span>咨</span>
					<span>询</span>
				</div>
				<svg id="contact-drawer-arrow" class="w-4 h-4 mt-2 transition-transform duration-300 md:group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>
				</svg>
			</div>
			
			<!-- 右侧内容区域 -->
			<div class="bg-blue-600 p-1 rounded-bl-lg rounded-tl-none">
				<div class="bg-white w-48 flex flex-col rounded-sm h-full">
					<div class="p-4 flex flex-col items-center">
 						<div class="text-lg font-bold text-gray-900 mb-3 tracking-wide">400-926-6655</div>
 						<a href="/contact#apply-form" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-center py-2 rounded-md font-bold transition-colors text-sm">办理咨询</a>
 					</div>
					<div class="border-t border-gray-100 p-4 flex flex-col items-center">
						<img src="/images/微信客服.jpg" alt="微信客服二维码" class="w-32 h-32 object-cover border border-gray-100 rounded" />
					</div>
				</div>
			</div>
		</div>

		<script>
			const btn = document.getElementById('mobile-menu-button');
			const menu = document.getElementById('mobile-menu');

			if (btn && menu) {
				btn.addEventListener('click', () => {
					menu.classList.toggle('hidden');
				});
			}

			const contactDrawer = document.getElementById('contact-drawer');
			const contactDrawerTab = document.getElementById('contact-drawer-tab');
			const contactDrawerArrow = document.getElementById('contact-drawer-arrow');

			if (contactDrawer && contactDrawerTab) {
				contactDrawerTab.addEventListener('click', (e) => {
					e.stopPropagation();
					contactDrawer.classList.toggle('translate-x-full');
					if (contactDrawerArrow) {
						contactDrawerArrow.classList.toggle('rotate-180');
					}
				});

				document.addEventListener('click', (e) => {
					if (!contactDrawer.contains(e.target)) {
						contactDrawer.classList.add('translate-x-full');
						if (contactDrawerArrow) {
							contactDrawerArrow.classList.remove('rotate-180');
						}
					}
				});
			}
		</script>
	</body>
</html>
