---
interface Props {
	type?: 'simple' | 'agent';
}

const { type = 'simple' } = Astro.props;
---

<div id="quick-apply-modal" class="fixed inset-0 z-50 hidden items-center justify-center" data-type={type}>
	<div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="modal-overlay"></div>
	<div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden transform transition-all">
		<div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-4">
			<h3 class="text-xl font-bold text-white" id="modal-title">立即申请</h3>
			<p class="text-blue-100 text-sm mt-1" id="modal-desc">填写信息，工作人员会尽快联系您</p>
		</div>
		<form id="modal-form" class="p-6 space-y-4">
			<div>
				<label class="block text-sm font-semibold text-gray-700 mb-1.5">姓名 <span class="text-red-500">*</span></label>
				<input type="text" name="name" required placeholder="请输入您的姓名" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" />
			</div>
			<div>
				<label class="block text-sm font-semibold text-gray-700 mb-1.5">电话 <span class="text-red-500">*</span></label>
				<input type="tel" name="phone" required placeholder="请输入您的手机号码" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" />
			</div>
			<div id="region-field" class="hidden">
				<label class="block text-sm font-semibold text-gray-700 mb-1.5">地区</label>
				<input type="text" name="region" placeholder="如：广东省深圳市" class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" />
			</div>
			<input type="hidden" name="source" id="modal-source" value="" />
			<div id="modal-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>
			<button type="submit" id="modal-submit-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition-colors text-base">提交信息</button>
		</form>
		<button id="modal-close" class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors">
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
		</button>
	</div>
</div>

<script>
	const WEBHOOK_URL = 'https://text.pingbal.com/webhook';

	const modal = document.getElementById('quick-apply-modal') as HTMLElement | null;
	const overlay = document.getElementById('modal-overlay');
	const closeBtn = document.getElementById('modal-close');
	const form = document.getElementById('modal-form') as HTMLFormElement | null;
	const statusEl = document.getElementById('modal-status') as HTMLElement | null;
	const submitBtn = document.getElementById('modal-submit-btn') as HTMLButtonElement | null;
	const sourceInput = document.getElementById('modal-source') as HTMLInputElement | null;
	const regionField = document.getElementById('region-field');
	const titleEl = document.getElementById('modal-title');
	const descEl = document.getElementById('modal-desc');

	function openModal(type: string, source: string, title?: string) {
		if (!modal) return;

		if (type === 'agent') {
			modal.dataset.type = 'agent';
			regionField?.classList.remove('hidden');
			if (titleEl) titleEl.textContent = title || '代理加盟咨询';
			if (descEl) descEl.textContent = '填写信息，了解立刷代理加盟政策';
		} else {
			modal.dataset.type = 'simple';
			regionField?.classList.add('hidden');
			if (titleEl) titleEl.textContent = title || '立即申请';
			if (descEl) descEl.textContent = '填写信息，工作人员会尽快联系您';
		}

		if (sourceInput) sourceInput.value = source;
		modal.dataset.product = title || source || (type === 'agent' ? '代理加盟' : 'POS机咨询');
		modal.classList.remove('hidden');
		modal.classList.add('flex');
		document.body.style.overflow = 'hidden';
	}

	function formatSubmitTime() {
		const now = new Date();
		const pad = (value: number) => String(value).padStart(2, '0');
		return `${now.getFullYear()}/${now.getMonth() + 1}/${now.getDate()} ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
	}

	function closeModal() {
		if (!modal) return;
		modal.classList.add('hidden');
		modal.classList.remove('flex');
		document.body.style.overflow = '';
		if (statusEl) {
			statusEl.classList.add('hidden');
		}
		if (form) form.reset();
	}

	overlay?.addEventListener('click', closeModal);
	closeBtn?.addEventListener('click', closeModal);

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeModal();
	});

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (!submitBtn || !statusEl) return;

		const formData = new FormData(form);
		const name = String(formData.get('name') ?? '').trim();
		const phone = String(formData.get('phone') ?? '').trim();
		const region = String(formData.get('region') ?? '').trim();
		const source = String(formData.get('source') ?? '').trim();

		if (!name || !phone) {
			statusEl.textContent = '请填写姓名和电话';
			statusEl.className = 'rounded-lg bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
			return;
		}

		submitBtn.disabled = true;
		submitBtn.textContent = '提交中...';

		const payload = {
			姓名: name,
			电话: phone,
			产品: modal?.dataset.product || source || 'POS机咨询',
			留言: region ? `地区：${region}` : '快速申请',
			网站: '立刷',
			来源: source || '弹窗申请',
			时间: formatSubmitTime(),
		};

		try {
			const response = await fetch(WEBHOOK_URL, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});

			if (!response.ok) {
				throw new Error('提交失败，请稍后重试');
			}

			form.reset();
			statusEl.textContent = '提交成功！工作人员会尽快联系您。';
			statusEl.className = 'rounded-lg bg-green-50 px-4 py-3 text-sm font-medium text-green-700';
			setTimeout(closeModal, 2000);
		} catch {
			statusEl.textContent = '提交失败，请稍后重试';
			statusEl.className = 'rounded-lg bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
		} finally {
			submitBtn.disabled = false;
			submitBtn.textContent = '提交信息';
		}
	});

	document.addEventListener('open-apply-modal', ((e: CustomEvent) => {
		const { type = 'simple', source = '', title } = e.detail || {};
		openModal(type, source, title);
	}) as EventListener);
</script>
