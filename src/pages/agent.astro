﻿﻿﻿﻿﻿---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout title="代理加盟 - 立刷POS" currentPath="/agent" description="立刷POS机代理加盟，嘉联支付旗下品牌，低门槛入驻，高比例分润，完善的培训体系和售后支持。成为立刷代理商，共享支付行业红利。" keywords="立刷POS代理,立刷代理加盟,POS机代理,POS机加盟,立刷分润,支付代理">

	<section class="relative bg-gradient-to-br from-blue-700 via-blue-600 to-blue-800 text-white py-20 md:py-28 overflow-hidden">
		<div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[420px] h-[420px] bg-white rounded-full blur-[120px] opacity-10 pointer-events-none"></div>
		<div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/4 w-[320px] h-[320px] bg-blue-400 rounded-full blur-[110px] opacity-15 pointer-events-none"></div>
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<span class="inline-block bg-white/20 text-white px-4 py-1.5 rounded-full text-sm font-medium mb-6">诚招全国代理</span>
			<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 tracking-tight leading-tight">
				加入立刷<br class="md:hidden" />共创支付事业
			</h1>
			<p class="text-xl text-blue-100 max-w-2xl mx-auto font-medium mb-10">嘉联支付旗下品牌，持牌合规运营。低门槛入驻、高比例分润、完善培训体系，助您快速开拓本地市场。</p>
			<div class="flex flex-wrap items-center justify-center gap-4">
				<a href="javascript:void(0)" data-apply="agent" data-source="代理加盟" data-title="代理加盟咨询" class="bg-white text-blue-600 hover:bg-blue-50 px-8 py-3.5 rounded-full font-bold text-lg transition-colors shadow-lg">立即咨询加盟</a>
				<a href="tel:400-926-6655" class="border border-white/50 text-white hover:bg-white/10 px-8 py-3.5 rounded-full font-bold text-lg transition-colors">400-926-6655</a>
			</div>
		</div>
	</section>

	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
		<Breadcrumbs items={[{label: '代理加盟'}]} />
	</div>

	<section class="py-16 md:py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-14">
				<h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">为什么选择立刷</h2>
				<p class="text-gray-500 text-lg max-w-2xl mx-auto">嘉联支付官方品牌，央行持牌机构，为代理商提供稳定、合规、可持续的合作模式</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
				<div class="text-center p-6 rounded-2xl border border-gray-100 hover:border-blue-200 hover:shadow-lg transition-all group">
					<div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-blue-600 transition-colors">
						<svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
					</div>
					<h3 class="text-lg font-bold text-gray-900 mb-2">央行持牌</h3>
					<p class="text-gray-500 text-sm leading-relaxed">嘉联支付持有中国人民银行颁发的《支付业务许可证》，合规运营，资金安全有保障</p>
				</div>
				<div class="text-center p-6 rounded-2xl border border-gray-100 hover:border-blue-200 hover:shadow-lg transition-all group">
					<div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-green-600 transition-colors">
						<svg class="w-8 h-8 text-green-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
					</div>
					<h3 class="text-lg font-bold text-gray-900 mb-2">高分润比例</h3>
					<p class="text-gray-500 text-sm leading-relaxed">交易分润持续稳定，激活奖励丰厚。交易不停，分润不止，长期可持续的收益模式</p>
				</div>
				<div class="text-center p-6 rounded-2xl border border-gray-100 hover:border-blue-200 hover:shadow-lg transition-all group">
					<div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-purple-600 transition-colors">
						<svg class="w-8 h-8 text-purple-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
					</div>
					<h3 class="text-lg font-bold text-gray-900 mb-2">低门槛入驻</h3>
					<p class="text-gray-500 text-sm leading-relaxed">无需大量资金囤货，灵活的代理级别，从个人创业到团队运营都能找到适合的合作方案</p>
				</div>
				<div class="text-center p-6 rounded-2xl border border-gray-100 hover:border-blue-200 hover:shadow-lg transition-all group">
					<div class="w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:bg-orange-600 transition-colors">
						<svg class="w-8 h-8 text-orange-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
					</div>
					<h3 class="text-lg font-bold text-gray-900 mb-2">全程扶持</h3>
					<p class="text-gray-500 text-sm leading-relaxed">提供产品培训、市场推广素材、技术支持和售后保障，让代理商无后顾之忧</p>
				</div>
			</div>
		</div>
	</section>

	<section class="py-16 md:py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-14">
				<h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">代理合作模式</h2>
				<p class="text-gray-500 text-lg max-w-2xl mx-auto">灵活的合作方案，满足不同阶段的创业需求</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-lg transition-shadow relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-blue-400"></div>
					<div class="text-center mb-6">
						<span class="inline-block bg-blue-50 text-blue-600 px-3 py-1 rounded-full text-sm font-semibold mb-4">初级代理</span>
						<div class="text-3xl font-extrabold text-gray-900">个人创业</div>
					</div>
					<ul class="space-y-3 mb-8">
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>适合个人创业者、兼职代理</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>低门槛启动，少量备货即可开展业务</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>享受基础分润和激活奖励</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>提供产品培训和业务指导</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>官方售后支持，客户问题有人处理</li>
					</ul>
					<a href="javascript:void(0)" data-apply="agent" data-source="代理加盟-初级" data-title="初级代理咨询" class="block w-full text-center bg-blue-50 text-blue-600 hover:bg-blue-100 px-6 py-3 rounded-xl font-bold transition-colors">咨询详情</a>
				</div>

				<div class="bg-white rounded-2xl p-8 shadow-sm border-2 border-blue-600 hover:shadow-lg transition-shadow relative overflow-hidden scale-[1.02]">
					<div class="absolute top-0 left-0 w-full h-1.5 bg-blue-600"></div>
					<div class="absolute top-4 right-4">
						<span class="bg-blue-600 text-white text-xs font-bold px-2.5 py-1 rounded-full">推荐</span>
					</div>
					<div class="text-center mb-6">
						<span class="inline-block bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-semibold mb-4">核心代理</span>
						<div class="text-3xl font-extrabold text-gray-900">团队运营</div>
					</div>
					<ul class="space-y-3 mb-8">
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>适合有团队、有本地商户资源的代理</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>更高分润比例，利润空间更大</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>可发展下级代理，享受团队分润</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>专属市场推广物料和技术培训</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>优先获取新产品和政策信息</li>
					</ul>
					<a href="javascript:void(0)" data-apply="agent" data-source="代理加盟-核心" data-title="核心代理申请" class="block w-full text-center bg-blue-600 text-white hover:bg-blue-700 px-6 py-3 rounded-xl font-bold transition-colors shadow-lg">立即申请</a>
				</div>

				<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-lg transition-shadow relative overflow-hidden">
					<div class="absolute top-0 left-0 w-full h-1 bg-orange-400"></div>
					<div class="text-center mb-6">
						<span class="inline-block bg-orange-50 text-orange-600 px-3 py-1 rounded-full text-sm font-semibold mb-4">战略代理</span>
						<div class="text-3xl font-extrabold text-gray-900">区域合作</div>
					</div>
					<ul class="space-y-3 mb-8">
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>适合有丰富行业经验的区域运营商</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>最高级别分润，独享区域市场红利</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>一对一专属客户经理服务</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>定制化合作方案和政策支持</li>
						<li class="flex items-start gap-3 text-sm text-gray-600"><svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>参与品牌活动、行业展会等推广</li>
					</ul>
					<a href="/contact?source=agent#apply-form" class="block w-full text-center bg-orange-50 text-orange-600 hover:bg-orange-100 px-6 py-3 rounded-xl font-bold transition-colors">咨询详情</a>
				</div>
			</div>
		</div>
	</section>

	<section class="py-16 md:py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-14">
				<h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">代理收益来源</h2>
				<p class="text-gray-500 text-lg max-w-2xl mx-auto">多元化的收益结构，确保代理商持续稳定盈利</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				<div class="bg-gradient-to-br from-blue-50 to-blue-100/50 rounded-2xl p-6">
					<div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg></div>
					<h3 class="font-bold text-gray-900 mb-2">交易分润</h3>
					<p class="text-sm text-gray-600 leading-relaxed">商户每笔交易均可获得分润收益，交易不停、分润不止，是核心收入来源</p>
				</div>
				<div class="bg-gradient-to-br from-green-50 to-green-100/50 rounded-2xl p-6">
					<div class="w-12 h-12 bg-green-600 rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"></path></svg></div>
					<h3 class="font-bold text-gray-900 mb-2">激活奖励</h3>
					<p class="text-sm text-gray-600 leading-relaxed">每激活一台设备即可获得现金奖励，激活越多奖励越高</p>
				</div>
				<div class="bg-gradient-to-br from-purple-50 to-purple-100/50 rounded-2xl p-6">
					<div class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg></div>
					<h3 class="font-bold text-gray-900 mb-2">团队管理奖</h3>
					<p class="text-sm text-gray-600 leading-relaxed">发展下级代理后，可享受团队交易量带来的管理收益</p>
				</div>
				<div class="bg-gradient-to-br from-orange-50 to-orange-100/50 rounded-2xl p-6">
					<div class="w-12 h-12 bg-orange-600 rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg></div>
					<h3 class="font-bold text-gray-900 mb-2">达标激励</h3>
					<p class="text-sm text-gray-600 leading-relaxed">完成月度/季度交易量目标，额外获得现金激励和实物奖励</p>
				</div>
			</div>
		</div>
	</section>

	<section class="py-16 md:py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-14">
				<h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">加盟流程</h2>
				<p class="text-gray-500 text-lg max-w-2xl mx-auto">简单四步，快速开启代理事业</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
				<div class="text-center">
					<div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-extrabold shadow-lg shadow-blue-600/30">1</div>
					<h3 class="font-bold text-gray-900 mb-2">咨询了解</h3>
					<p class="text-sm text-gray-500">通过电话或在线咨询了解代理政策和合作方案</p>
				</div>
				<div class="text-center">
					<div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-extrabold shadow-lg shadow-blue-600/30">2</div>
					<h3 class="font-bold text-gray-900 mb-2">资质审核</h3>
					<p class="text-sm text-gray-500">提交个人或企业资料，完成合作资质审核</p>
				</div>
				<div class="text-center">
					<div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 text-white text-2xl font-extrabold shadow-lg shadow-blue-600/30">3</div>
