---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
	const newsEntries = await getCollection('news');
	const sorted = newsEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
	return sorted.map((entry, index) => ({
		params: { slug: entry.id.replace(/\.md$/, '') },
		props: {
			entry,
			prev: index > 0 ? sorted[index - 1] : null,
			next: index < sorted.length - 1 ? sorted[index + 1] : null,
		},
	}));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} - 立刷POS官网资讯`} currentPath={`/news/${entry.id.replace(/\.md$/, '')}`} description={entry.data.description} keywords={entry.data.category ? `立刷POS机,${entry.data.category},POS机知识` : '立刷POS机,POS机知识'} ogImage={entry.data.image || '/images/logo.webp'}>
	<div class="max-w-6xl mx-auto px-0 sm:px-6 lg:px-8 py-0 md:py-12">
		<div class="px-4 md:px-0">
			<Breadcrumbs items={[{label: '资讯动态', href: '/news'}, {label: entry.data.title}]} />
		</div>

		<div class="flex flex-col lg:flex-row gap-8 items-start mt-2">
			<!-- 左侧 CTA 侧边栏 (桌面端粘性) -->
			<aside class="hidden lg:block lg:w-52 flex-shrink-0 lg:sticky lg:top-24 lg:self-start space-y-4">
				<!-- 在线咨询卡片 -->
				<div class="bg-gradient-to-br from-blue-600 to-blue-700 rounded-xl p-5 shadow-lg text-white">
					<div class="flex items-center gap-2 mb-3">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
						<span class="font-bold text-sm">在线咨询</span>
					</div>
					<p class="text-blue-100 text-xs leading-relaxed mb-4">专业顾问一对一解答办理流程、费率政策、激活条件等问题</p>
					<a href="/contact#apply-form" class="block w-full rounded-lg bg-white text-blue-600 px-4 py-2.5 text-center text-sm font-bold hover:bg-blue-50 transition-colors shadow-sm">立即咨询</a>
				</div>

				<!-- 电话咨询卡片 -->
				<div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
					<div class="flex items-center gap-2 mb-3">
						<div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
							<svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
						</div>
						<div>
							<div class="text-xs text-gray-500">电话咨询</div>
							<div class="font-bold text-gray-900 text-sm">400-926-6655</div>
						</div>
					</div>
					<a href="tel:400-926-6655" class="block w-full rounded-lg border-2 border-green-500 text-green-600 px-4 py-2 text-center text-sm font-bold hover:bg-green-50 transition-colors">一键拨打</a>
					<div class="mt-2 text-center text-xs text-gray-400">7x24小时全国服务热线</div>
				</div>

				<!-- 微信客服卡片 -->
				<div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm">
					<div class="flex items-center gap-2 mb-3">
						<div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0">
							<svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-7.062-6.122zM14.033 13.3c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982z"/></svg>
						</div>
						<div>
							<div class="font-bold text-gray-900 text-sm">微信客服</div>
							<div class="text-xs text-gray-400">专属一对一服务</div>
						</div>
					</div>
					<div class="bg-gray-50 rounded-lg p-3 flex flex-col items-center">
						<img src="/images/微信客服.jpg" alt="微信客服二维码" class="w-28 h-28 rounded-lg object-cover border-2 border-white shadow-sm" />
						<p class="mt-3 text-xs text-gray-500 font-medium">扫码添加客服微信</p>
					</div>
				</div>
			</aside>

			<!-- 右侧文章主体 -->
			<div class="flex-1 min-w-0">
				<article class="bg-white md:rounded-2xl md:shadow-sm p-4 md:p-8 lg:p-12">
					<header class="mb-8 md:mb-10 text-center border-b border-gray-100 pb-8 md:pb-10">
						{entry.data.image && (
							<div class="mb-6 rounded-xl overflow-hidden bg-gray-100">
								<img src={entry.data.image} alt={entry.data.title} class="w-full aspect-[16/9] object-contain" />
							</div>
						)}
						<h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 mb-5 md:mb-6 leading-tight">
							{entry.data.title}
						</h1>
						<div class="flex items-center justify-center text-gray-500 text-sm">
							<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
							<time datetime={entry.data.date.toISOString()}>
								{entry.data.date.toLocaleDateString('zh-CN', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
						</div>
					</header>

					<div class="prose prose-blue prose-base md:prose-lg max-w-none text-gray-700">
						<Content />
					</div>
				</article>

				<!-- 上一篇/下一篇 -->
				<div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
					{next ? (
						<a href={`/news/${next.id.replace(/\.md$/, '')}`} class="group bg-white rounded-xl border border-gray-200 p-5 hover:border-blue-300 hover:shadow-md transition-all">
							<div class="text-xs text-gray-400 mb-2 flex items-center gap-1">
								<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
								上一篇
							</div>
							<div class="text-sm font-medium text-gray-800 group-hover:text-blue-600 transition-colors line-clamp-2">{next.data.title}</div>
						</a>
					) : (
						<div class="bg-gray-50 rounded-xl border border-gray-100 p-5 opacity-50">
							<div class="text-xs text-gray-400 mb-2">上一篇</div>
							<div class="text-sm text-gray-400">没有更多了</div>
						</div>
					)}
					{prev ? (
						<a href={`/news/${prev.id.replace(/\.md$/, '')}`} class="group bg-white rounded-xl border border-gray-200 p-5 hover:border-blue-300 hover:shadow-md transition-all text-right">
							<div class="text-xs text-gray-400 mb-2 flex items-center gap-1 justify-end">
								下一篇
								<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
							</div>
							<div class="text-sm font-medium text-gray-800 group-hover:text-blue-600 transition-colors line-clamp-2">{prev.data.title}</div>
						</a>
					) : (
						<div class="bg-gray-50 rounded-xl border border-gray-100 p-5 opacity-50 text-right">
							<div class="text-xs text-gray-400 mb-2">下一篇</div>
							<div class="text-sm text-gray-400">没有更多了</div>
						</div>
					)}
				</div>
			</div>
		</div>
	</div>
</Layout>
