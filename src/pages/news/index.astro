---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="资讯动态 - 立刷POS">
	<!-- Hero Section -->
	<section class="relative bg-gray-900 text-white py-20 overflow-hidden">
		<!-- 半透明遮罩 -->
		<div class="absolute inset-0 bg-black/30 pointer-events-none"></div>
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center drop-shadow-md">
			<h1 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight">资讯动态</h1>
			<p class="text-xl text-gray-200 max-w-2xl mx-auto font-medium">掌握行业最新动态，了解立刷最新产品与服务</p>
		</div>
	</section>

	<section class="py-16 bg-gray-50 min-h-screen">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{sortedNews.map((post) => (
					<a href={`/news/${post.id.replace(/\.md$/, '')}`} class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden group flex flex-col h-full">
						<div class="p-6 flex-grow flex flex-col">
							<div class="text-xs text-blue-600 font-semibold mb-2">
								{post.data.date.toLocaleDateString('zh-CN', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</div>
							<h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors">
								{post.data.title}
							</h2>
							<p class="text-gray-600 text-sm line-clamp-3 mb-4 flex-grow">
								{post.data.description}
							</p>
							<div class="text-blue-600 text-sm font-medium mt-auto flex items-center">
								阅读全文
								<svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
							</div>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>
