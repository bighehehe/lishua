---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['全部', ...new Set(allNews.map(post => post.data.category).filter(Boolean))];
const years = [...new Set(allNews.map(post => post.data.date.getFullYear()))].sort((a, b) => b - a);

const PAGE_SIZE = 6;
const totalPages = Math.ceil(sortedNews.length / PAGE_SIZE);
---

<Layout title="资讯动态 - 立刷POS" currentPath="/news" description="立刷POS机资讯动态，了解立刷最新产品信息、办理指南、费率政策、激活教程与行业动态。专业POS机知识库，助您全面了解立刷POS机。" keywords="立刷POS资讯,立刷POS机办理指南,POS机知识,立刷新闻动态">
	<!-- Hero Section -->
	<section class="relative bg-blue-600 text-white py-20 md:py-28 overflow-hidden">
		<div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[420px] h-[420px] bg-blue-400 rounded-full blur-[120px] opacity-20 pointer-events-none"></div>
		<div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/4 w-[320px] h-[320px] bg-blue-500 rounded-full blur-[110px] opacity-20 pointer-events-none"></div>
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center drop-shadow-md">
			<h1 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight">资讯动态</h1>
			<p class="text-xl text-gray-200 max-w-2xl mx-auto font-medium">掌握行业最新动态，了解立刷最新产品与服务</p>
		</div>
	</section>

	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
		<Breadcrumbs items={[{label: '资讯动态'}]} />
	</div>

	<section class="py-8 md:py-16 bg-gray-50 min-h-screen">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-10">
				<!-- 分类按钮 -->
				<div class="flex flex-wrap gap-3" id="category-filters">
					{categories.map((cat, index) => (
						<button
							class={`px-5 py-2 rounded-full text-sm font-medium transition-colors cursor-pointer ${index === 0 ? 'bg-blue-600 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-blue-300 hover:text-blue-600'}`}
							data-category={cat}
						>
							{cat}
						</button>
					))}
				</div>

				<!-- 年份下拉框 -->
				<div class="relative">
					<select id="year-filter" class="appearance-none bg-white border border-gray-200 rounded-full px-5 py-2 pr-10 text-sm font-medium text-gray-600 cursor-pointer hover:border-blue-300 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100 transition-colors">
						<option value="全部">全部年份</option>
						{years.map((year) => (
							<option value={String(year)}>{year}年</option>
						))}
					</select>
					<div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
						<svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
					</div>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="news-grid">
				{sortedNews.map((post, index) => (
					<a
						href={`/news/${post.id.replace(/\.md$/, '')}`}
						class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden group flex flex-col h-full news-card"
						data-category={post.data.category || '全部'}
						data-year={post.data.date.getFullYear()}
						data-page={Math.floor(index / PAGE_SIZE) + 1}
					>
						{post.data.image && (
							<div class="aspect-[16/9] overflow-hidden bg-gray-100">
								<img src={post.data.image} alt={post.data.title} class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300" />
							</div>
						)}
						<div class="p-6 flex-grow flex flex-col">
							<div class="flex items-center gap-3 mb-3">
								<span class="text-xs text-blue-600 font-semibold">
									{post.data.date.toLocaleDateString('zh-CN', {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</span>
								<span class="text-xs bg-blue-50 text-blue-600 px-2 py-0.5 rounded-full font-medium">
									{post.data.category || '全部'}
								</span>
							</div>
							<h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors">
								{post.data.title}
							</h2>
							<p class="text-gray-600 text-sm line-clamp-3 mb-4 flex-grow">
								{post.data.description}
							</p>
							<div class="text-blue-600 text-sm font-medium mt-auto flex items-center">
								阅读全文
								<svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
							</div>
						</div>
					</a>
				))}
			</div>

			<!-- 分页组件 -->
			{totalPages > 1 && (
				<div class="mt-12 flex justify-center" id="pagination-container">
					<nav class="flex items-center gap-2" aria-label="分页导航">
						<button
							id="prev-btn"
							class="px-4 py-2 rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-blue-600 hover:border-blue-300 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
							disabled
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
						</button>
						<div id="page-numbers" class="flex items-center gap-1">
						</div>
						<button
							id="next-btn"
							class="px-4 py-2 rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-blue-600 hover:border-blue-300 transition-colors"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
						</button>
					</nav>
				</div>
			)}
		</div>
	</section>

	<section class="py-20 bg-blue-600">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl md:text-4xl font-bold text-white mb-5">想了解更多产品信息？</h2>
			<p class="text-blue-100 text-lg mb-8 max-w-2xl mx-auto">直接联系客服，获取一对一咨询和最新办理方案。</p>
			<div class="flex flex-wrap items-center justify-center gap-4">
				<a href="javascript:void(0)" data-apply="simple" data-source="资讯动态" class="bg-white text-blue-600 hover:bg-blue-50 px-8 py-3.5 rounded-full font-bold text-lg transition-colors shadow-lg">在线咨询</a>
				<a href="tel:400-926-6655" class="border border-white/50 text-white hover:bg-white/10 px-8 py-3.5 rounded-full font-bold text-lg transition-colors">400-926-6655</a>
			</div>
		</div>
	</section>

	<script>
		const filterContainer = document.getElementById('category-filters');
		const newsGrid = document.getElementById('news-grid');
		const yearFilter = document.getElementById('year-filter');
		const paginationContainer = document.getElementById('pagination-container');
		const pageNumbersContainer = document.getElementById('page-numbers');
		const prevBtn = document.getElementById('prev-btn');
		const nextBtn = document.getElementById('next-btn');

		if (filterContainer && newsGrid && yearFilter) {
			const buttons = filterContainer.querySelectorAll('button');
			const cards = newsGrid.querySelectorAll('.news-card');
			let activeCategory = '全部';
			let activeYear = '全部';
			let currentPage = 1;
			const PAGE_SIZE = 3;

			function getFilteredCards() {
				return Array.from(cards).filter((card) => {
					const el = card;
					const cardCategory = el.getAttribute('data-category');
					const cardYear = el.getAttribute('data-year');
					const matchCategory = activeCategory === '全部' || cardCategory === activeCategory;
					const matchYear = activeYear === '全部' || cardYear === activeYear;
					return matchCategory && matchYear;
				});
			}

			function updatePagination() {
				const filteredCards = getFilteredCards();
				const totalFilteredPages = Math.ceil(filteredCards.length / PAGE_SIZE);

				if (totalFilteredPages <= 1) {
					paginationContainer.style.display = 'none';
				} else {
					paginationContainer.style.display = 'flex';
				}

				if (currentPage > totalFilteredPages) {
					currentPage = totalFilteredPages || 1;
				}

				prevBtn.disabled = currentPage <= 1;
				nextBtn.disabled = currentPage >= totalFilteredPages;

				pageNumbersContainer.innerHTML = '';
				for (let i = 1; i <= totalFilteredPages; i++) {
					const btn = document.createElement('button');
					btn.textContent = i;
					btn.className = `w-10 h-10 rounded-lg text-sm font-medium transition-colors cursor-pointer ${
						i === currentPage
							? 'bg-blue-600 text-white'
							: 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50 hover:text-blue-600 hover:border-blue-300'
					}`;
					btn.addEventListener('click', () => {
						currentPage = i;
						updateDisplay();
					});
					pageNumbersContainer.appendChild(btn);
				}
			}

			function updateDisplay() {
				const filteredCards = getFilteredCards();

				cards.forEach((card) => {
					card.style.display = 'none';
				});

				const startIndex = (currentPage - 1) * PAGE_SIZE;
				const endIndex = startIndex + PAGE_SIZE;
				const pageCards = filteredCards.slice(startIndex, endIndex);

				pageCards.forEach((card) => {
					card.style.display = '';
				});

				updatePagination();
			}

			buttons.forEach((btn) => {
				btn.addEventListener('click', () => {
					activeCategory = btn.getAttribute('data-category');
					buttons.forEach((b) => {
						b.className = 'px-5 py-2 rounded-full text-sm font-medium transition-colors cursor-pointer bg-white text-gray-600 border border-gray-200 hover:border-blue-300 hover:text-blue-600';
					});
					btn.className = 'px-5 py-2 rounded-full text-sm font-medium transition-colors cursor-pointer bg-blue-600 text-white';
					currentPage = 1;
					updateDisplay();
				});
			});

			yearFilter.addEventListener('change', () => {
				activeYear = yearFilter.value;
				currentPage = 1;
				updateDisplay();
			});

			prevBtn.addEventListener('click', () => {
				if (currentPage > 1) {
					currentPage--;
					updateDisplay();
				}
			});

			nextBtn.addEventListener('click', () => {
				const filteredCards = getFilteredCards();
				const totalFilteredPages = Math.ceil(filteredCards.length / PAGE_SIZE);
				if (currentPage < totalFilteredPages) {
					currentPage++;
					updateDisplay();
				}
			});

			updateDisplay();
		}
	</script>
</Layout>
