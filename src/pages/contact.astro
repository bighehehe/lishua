---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout title="联系我们 - 立刷POS" currentPath="/contact" description="联系立刷POS机官方客服，在线咨询POS机办理流程、费率政策与售后服务。客服热线400-926-6655，7x24小时全国服务。" keywords="联系立刷,立刷POS客服,POS机咨询,POS机办理电话,立刷客服热线">
	<section class="relative bg-blue-600 text-white py-20 md:py-28 overflow-hidden">
		<div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[420px] h-[420px] bg-blue-400 rounded-full blur-[120px] opacity-20 pointer-events-none"></div>
		<div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/4 w-[320px] h-[320px] bg-blue-500 rounded-full blur-[110px] opacity-20 pointer-events-none"></div>
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center drop-shadow-md">
			<h1 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight">联系我们</h1>
			<p class="text-xl text-gray-200 max-w-2xl mx-auto font-medium">随时为您提供专业、周到的服务支持</p>
		</div>
	</section>

	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
		<Breadcrumbs items={[{label: '联系我们'}]} />
	</div>

	<section class="py-8 md:py-16 bg-gray-50 border-t border-gray-100">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
				<div class="rounded-2xl bg-white p-8 shadow-sm border border-blue-50">
					<div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
					</div>
					<h2 class="text-xl font-bold text-gray-900 mb-3">快速响应</h2>
					<p class="text-gray-600 leading-relaxed">工作时间优先响应咨询与申请需求，帮助商户更快进入办理流程。</p>
				</div>
				<div class="rounded-2xl bg-white p-8 shadow-sm border border-blue-50">
					<div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
					</div>
					<h2 class="text-xl font-bold text-gray-900 mb-3">顾问协助</h2>
					<p class="text-gray-600 leading-relaxed">根据经营场景匹配机型与办理建议，减少无效沟通和重复提交资料。</p>
				</div>
				<div class="rounded-2xl bg-white p-8 shadow-sm border border-blue-50">
					<div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
					</div>
					<h2 class="text-xl font-bold text-gray-900 mb-3">售后支持</h2>
					<p class="text-gray-600 leading-relaxed">设备激活、使用问题、结算咨询均有专人跟进，减少使用顾虑。</p>
				</div>
			</div>
		</div>
	</section>

	<section class="py-16 md:py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col lg:flex-row gap-16 items-stretch">
				<!-- 联系信息 -->
				<div class="lg:w-1/3 flex flex-col">
					<h2 class="text-3xl font-bold text-gray-900 mb-8">联系方式</h2>
					
					<div class="space-y-8 flex-1">
						<div class="flex items-start">
							<div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center mr-4">
								<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
							</div>
							<div>
								<h3 class="text-lg font-bold text-gray-900 mb-1">客服热线</h3>
								<p class="text-gray-600">400-926-6655</p>
								<p class="text-sm text-gray-500 mt-1">服务时间：7x24小时全天候</p>
							</div>
						</div>

						<div class="flex items-start">
							<div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center mr-4">
								<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
							</div>
							<div>
								<h3 class="text-lg font-bold text-gray-900 mb-1">公司地址</h3>
								<p class="text-gray-600">深圳市南山区嘉联支付大厦</p>
							</div>
						</div>

						<div class="bg-gray-50 rounded-2xl p-6 text-center mt-4">
							<img src="/images/微信客服.jpg" alt="微信客服二维码" class="mx-auto w-32 h-32 rounded-xl object-cover border border-gray-200 mb-3" />
							<p class="text-sm font-medium text-gray-700">微信客服</p>
							<p class="text-xs text-gray-400 mt-1">扫码添加客服获取专属协助</p>
						</div>
					</div>
				</div>

				<!-- 在线留言表单 -->
				<div id="apply-form" class="lg:w-2/3 bg-gray-50 rounded-2xl p-8 md:p-12 scroll-mt-24">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">在线申请办理 / 留言</h2>
					<form id="contact-form" class="space-y-6">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label for="name" class="block text-sm font-medium text-gray-700 mb-2">您的姓名</label>
								<input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-shadow" placeholder="请输入您的姓名" required>
							</div>
							<div>
								<label for="phone" class="block text-sm font-medium text-gray-700 mb-2">联系电话</label>
								<input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-shadow" placeholder="请输入您的手机号码" required>
							</div>
						</div>
						
						<div>
							<label for="company" class="block text-sm font-medium text-gray-700 mb-2">公司名称</label>
							<input type="text" id="company" name="company" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-shadow" placeholder="请输入您的公司名称或门店名称">
						</div>

						<div>
							<label for="message" class="block text-sm font-medium text-gray-700 mb-2">留言内容</label>
							<textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-shadow resize-none" placeholder="请简要描述您的需求或疑问..." required></textarea>
						</div>

						<p id="form-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></p>
						
						<button type="submit" class="w-full bg-blue-600 text-white font-bold py-4 rounded-lg hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg">
							提交信息
						</button>
					</form>
				</div>
			</div>
		</div>
	</section>

	<script>
		const FEISHU_WEBHOOK_URL = 'https://www.feishu.cn/flow/api/trigger-webhook/fcf533eb2a782b972061b0ec406f3dc7';

		const form = document.getElementById('contact-form');
		const status = document.getElementById('form-status');

		if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
			form.addEventListener('submit', async (event) => {
				event.preventDefault();

				const submitButton = form.querySelector('button[type="submit"]');
				if (!(submitButton instanceof HTMLButtonElement)) {
					return;
				}

				const formData = new FormData(form);
				const name = String(formData.get('name') ?? '').trim();
				const phone = String(formData.get('phone') ?? '').trim();
				const company = String(formData.get('company') ?? '').trim();
				const message = String(formData.get('message') ?? '').trim();

				if (!name || !phone || !message) {
					status.textContent = '请完整填写姓名、电话和留言内容。';
					status.className = 'rounded-lg bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
					return;
				}

				status.className = 'hidden rounded-lg px-4 py-3 text-sm font-medium';
				submitButton.disabled = true;
				submitButton.textContent = '提交中...';

				try {
					const response = await fetch(FEISHU_WEBHOOK_URL, {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
						},
						body: JSON.stringify({
							name,
							phone,
							company,
							message,
							source: '立刷POS官网',
							submit_time: new Intl.DateTimeFormat('zh-CN', {
								timeZone: 'Asia/Shanghai',
								year: 'numeric',
								month: '2-digit',
								day: '2-digit',
								hour: '2-digit',
								minute: '2-digit',
								second: '2-digit',
								hour12: false,
							}).format(new Date()),
						}),
					});

					if (!response.ok) {
						throw new Error('提交失败，请稍后重试');
					}

					form.reset();
					status.textContent = '提交成功，我们的工作人员会尽快联系您。';
					status.className = 'rounded-lg bg-green-50 px-4 py-3 text-sm font-medium text-green-700';
				} catch (error) {
					const msg = error instanceof Error ? error.message : '提交失败，请稍后重试';
					status.textContent = msg;
					status.className = 'rounded-lg bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
				} finally {
					submitButton.disabled = false;
					submitButton.textContent = '提交信息';
				}
			});
		}
	</script>
</Layout>
