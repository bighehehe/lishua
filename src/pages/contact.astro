---
import Layout from '../layouts/Layout.astro';
---

<Layout title="联系我们 - 立刷POS">
	<section class="relative bg-gray-900 text-white py-20 overflow-hidden">
		<!-- 半透明遮罩 -->
		<div class="absolute inset-0 bg-black/30 pointer-events-none"></div>
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center drop-shadow-md">
			<h1 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight">联系我们</h1>
			<p class="text-xl text-gray-200 max-w-2xl mx-auto font-medium">随时为您提供专业、周到的服务支持</p>
		</div>
	</section>

	<section class="py-16 md:py-24 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex flex-col lg:flex-row gap-16">
				<!-- 联系信息 -->
				<div class="lg:w-1/3">
					<h2 class="text-3xl font-bold text-gray-900 mb-8">联系方式</h2>
					
					<div class="space-y-8">
						<div class="flex items-start">
							<div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center mr-4">
								<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
							</div>
							<div>
								<h3 class="text-lg font-bold text-gray-900 mb-1">客服热线</h3>
								<p class="text-gray-600">400-000-0000</p>
								<p class="text-sm text-gray-500 mt-1">服务时间：7x24小时全天候</p>
							</div>
						</div>
						
						<div class="flex items-start">
							<div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center mr-4">
								<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
							</div>
							<div>
								<h3 class="text-lg font-bold text-gray-900 mb-1">电子邮箱</h3>
								<p class="text-gray-600">service@lishua.com</p>
								<p class="text-sm text-gray-500 mt-1">业务合作及投诉建议</p>
							</div>
						</div>

						<div class="flex items-start">
							<div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center mr-4">
								<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
							</div>
							<div>
								<h3 class="text-lg font-bold text-gray-900 mb-1">公司地址</h3>
								<p class="text-gray-600">深圳市南山区科技园xx大厦</p>
							</div>
						</div>
					</div>
				</div>

				<!-- 在线留言表单 -->
				<div class="lg:w-2/3 bg-gray-50 rounded-2xl p-8 md:p-12">
					<h2 class="text-2xl font-bold text-gray-900 mb-6">在线申请办理 / 留言</h2>
					<form class="space-y-6" onsubmit="event.preventDefault(); alert('提交成功，我们的工作人员会尽快联系您！');">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div>
								<label for="name" class="block text-sm font-medium text-gray-700 mb-2">您的姓名</label>
								<input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-shadow" placeholder="请输入您的姓名" required>
							</div>
							<div>
								<label for="phone" class="block text-sm font-medium text-gray-700 mb-2">联系电话</label>
								<input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-shadow" placeholder="请输入您的手机号码" required>
							</div>
						</div>
						
						<div>
							<label for="product" class="block text-sm font-medium text-gray-700 mb-2">意向产品</label>
							<select id="product" name="product" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-shadow bg-white">
								<option value="none">请选择您感兴趣的产品（可选）</option>
								<option value="ls1">立刷1</option>
								<option value="ls-cloud">立刷云电签</option>
								<option value="other">其他 / 咨询</option>
							</select>
						</div>

						<div>
							<label for="message" class="block text-sm font-medium text-gray-700 mb-2">留言内容</label>
							<textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-shadow resize-none" placeholder="请简要描述您的需求或疑问..." required></textarea>
						</div>
						
						<button type="submit" class="w-full bg-blue-600 text-white font-bold py-4 rounded-lg hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg">
							提交信息
						</button>
					</form>
				</div>
			</div>
		</div>
	</section>
</Layout>
